# ════════════════════════════════════════════════════════════════
# LENCHO BACKEND CONFIGURATION
# Copy this to .env and fill in your values
# NEVER commit .env to Git (it's in .gitignore)
# ════════════════════════════════════════════════════════════════

# ── DATABASE ──────────────────────────────────────────────────────
# MongoDB Connection String
# 🔴 FOR PRODUCTION (MongoDB Atlas):
# 1. Go: https://account.mongodb.com
# 2. Create cluster → Get connection string
# 3. Replace <password> and <dbname>
# Example: mongodb+srv://lencho_admin:Strong@Password123@lencho-cluster.xxxxx.mongodb.net/lencho-db?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://lencho_admin:PASSWORD_HERE@lencho-cluster.xxxxx.mongodb.net/lencho-db?retryWrites=true&w=majority

# ── SESSION & SECURITY ────────────────────────────────────────────
# Generate strong random keys:
# TERMINAL: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=generate-random-key-and-paste-here
JWT_SECRET=generate-another-random-key-and-paste-here

# ── ENVIRONMENT ───────────────────────────────────────────────────
# 🔴 For Render: NODE_ENV=production
NODE_ENV=development
# development or production

# Server port (Render overrides this automatically)
PORT=30054

# ── CORS ALLOWED ORIGINS ──────────────────────────────────────────
# For production, set to your actual domain
CORS_ORIGIN=http://localhost:3000,http://localhost:30054,https://lencho.in,https://www.lencho.in,https://api.lencho.in

# ── SMS & OTP ──────────────────────────────────────────────────────
# Fast2SMS API key (optional, for SMS OTP verification)
# Get free key from: https://www.fast2sms.com
# Leave empty to disable SMS (OTPs will show in console)
FAST2SMS_KEY=

# ── ADMIN CREDENTIALS (Change before production!) ─────────────────
ADMIN_EMAIL=admin@lencho.in
ADMIN_PASSWORD=Admin@123456

# ── BUSINESS SETTINGS ─────────────────────────────────────────────
# WhatsApp Business number (for chat widget)
WHATSAPP_NUMBER=919999999999
STORE_EMAIL=business@lencho.in
STORE_PHONE=+91-7404217625

# ── PAYMENT GATEWAYS (Optional) ───────────────────────────────────
# Razorpay (for card/UPI payments)
RAZORPAY_KEY_ID=
RAZORPAY_SECRET=

# ── EMAIL CONFIGURATION (Optional for order notifications) ────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@lencho.in

# ════════════════════════════════════════════════════════════════
# 🚀 PRODUCTION DEPLOYMENT CHECKLIST
# ════════════════════════════════════════════════════════════════
# 
# Before pushing to Render:
# [ ] MONGODB_URI updated with real MongoDB Atlas connection string
# [ ] JWT_SECRET generated with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# [ ] SESSION_SECRET generated with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# [ ] NODE_ENV set to 'production'
# [ ] ADMIN_PASSWORD changed to something secure
# [ ] CORS_ORIGIN includes your domain (https://lencho.in)
# [ ] All secrets added to Render Environment Variables (NOT hardcoded)
# [ ] Database backup created before first deployment
#
# ════════════════════════════════════════════════════════════════

# ── SHIPMENT & LOGISTICS (Optional) ───────────────────────────
# Shiprocket API (for shipping integration)
SHIPROCKET_API_TOKEN=
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=

# ── GOOGLE APIs (Optional) ────────────────────────────────────
# For analytics and optimization
GOOGLE_ANALYTICS_ID=
GOOGLE_SEARCH_CONSOLE_ID=

# ─ BUSINESS DETAILS ───────────────────────────────────────────
STORE_NAME=Lencho
STORE_EMAIL=lencho.official01@gmail.com
STORE_PHONE=+91 7404217625
GSTIN=27XXXXX1234X1ZX

# ─ API KEYS & TOKENS ──────────────────────────────────────────
# JWT Secret (if using JWT authentication)
JWT_SECRET=

# ─ MISC SETTINGS ──────────────────────────────────────────────
# Site URL for links in emails
SITE_URL=https://lencho.in
API_URL=https://lencho-backend.onrender.com
